# ─── LiveKit Cloud ───────────────────────────────────────────────────────
# https://cloud.livekit.io → Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Groq (LLM) ──────────────────────────────────────────────────────────
# https://console.groq.com → API Keys
GROQ_API_KEY=
# Optional overrides:
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TEMPERATURE=0.4

# ─── Smallest.ai (STT + TTS) ─────────────────────────────────────────────
# https://console.smallest.ai/apikeys  — one key covers both STT (Pulse)
# and TTS (Lightning v3.1, ~100ms latency, 80+ voices).
SMALLEST_API_KEY=
# Optional TTS overrides:
SMALLEST_TTS_MODEL=lightning-v3.1
# Browse voices in the Smallest.ai console. "sophia" is a warm female default.
SMALLEST_VOICE_ID=sophia
# STT language. "en" for English, or "multi" for 39-language auto-detection.
SMALLEST_STT_LANGUAGE=en

# ─── Noveum (tracing + NovaSynth + NovaPilot) ────────────────────────────
# https://noveum.ai → Settings → API Keys
NOVEUM_API_KEY=
NOVEUM_PROJECT=voice-workshop
NOVEUM_ENV=workshop
