# ─── Anthropic (for Claude Code) ─────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── LiveKit Cloud ───────────────────────────────────────────────────────
# https://cloud.livekit.io → Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Deepgram (STT) ──────────────────────────────────────────────────────
# https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=

# ─── Groq (LLM) ──────────────────────────────────────────────────────────
# https://console.groq.com → API Keys
GROQ_API_KEY=
# Optional overrides:
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TEMPERATURE=0.4

# ─── ElevenLabs (TTS) ────────────────────────────────────────────────────
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_turbo_v2_5
# Default voice = "Adam" (en-US, male). Browse voices at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ─── Noveum (tracing + NovaSynth + NovaPilot) ────────────────────────────
# https://noveum.ai → Settings → API Keys
NOVEUM_API_KEY=
NOVEUM_PROJECT=voice-workshop
NOVEUM_ENV=workshop
